# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — your secrets stay local.

# Groq (free tier — get a key at https://console.groq.com/keys)
GROQ_API_KEY=

# Anthropic (paid; get a key at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Langfuse (free tier — get keys at https://cloud.langfuse.com)
# Used in Phase 4 for tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
